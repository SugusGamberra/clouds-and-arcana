---
import Layout from '../layouts/Layout.astro';
import { serviciosTarot } from '../data/servicios';
---

<Layout title="Servicios y Tarifas">
    <div class="max-w-4xl mx-auto py-10 px-4 relative z-10">
        <h1 class="text-4xl font-bold mb-4 text-[#cfb4b8] text-center font-serif">Mis Servicios</h1>
        <p class="text-lg text-texto/70 mb-10 text-center italic">Encuentra la claridad que necesitas a través del Tarot y las Runas.</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {serviciosTarot.map((servicio) => (
            <div class={`p-6 rounded-[30px] border flex flex-col justify-between backdrop-blur-md ${servicio.destacado ? 'md:col-span-2 border-[#cfb4b8] bg-white/40 shadow-lg scale-[1.02]' : 'border-white/50 bg-white/20 hover:bg-white/30 transition-all'}`}>
                <div>
                    <h3 class="text-2xl font-bold text-texto mb-2 font-serif">
                        {servicio.nombre} {servicio.destacado && '👑'}
                    </h3>
                    <p class="text-texto/80 font-medium italic text-sm">Formato: {servicio.formato}</p>
                    
                    <p class="text-sm text-texto/60 mt-4 leading-relaxed italic">
                        {servicio.descripcion}
                    </p>
                </div>
                
                <div class="mt-8 flex justify-between items-end">
                    <p class="text-3xl font-bold text-texto font-serif">{servicio.precio}</p>
                    <a href={`/reserva?servicio=${encodeURIComponent(servicio.nombre)}`} class="px-6 py-2 bg-[#cfb4b8] hover:bg-[#bfa3a7] text-white font-bold rounded-full transition-all shadow-md">Lo quiero</a>
                </div>
            </div>
        ))}
        </div>
    </div>
</Layout>