---
import Layout from '../layouts/Layout.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import YouTubeFeed from '../components/YouTubeFeed.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import nubeImg from '../assets/nube.png';

const posts = await getCollection('oraculo');
const postsOrdenados = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<Layout title="El Oráculo - Blog">
    <div class="max-w-[1100px] mx-auto py-12 px-6 relative z-10">
        
        <div class="absolute -top-10 -left-60 opacity-100 -z-10 pointer-events-none">
            <Image src={nubeImg} alt="Nube" class="w-100 h-auto" />
        </div>
        <div class="absolute top-50 -right-90 opacity-100 -z-10 pointer-events-none">
            <Image src={nubeImg} alt="Nube" class="w-120 h-auto scale-x-[-1]" />
        </div>

        <header class="text-center mb-20 shrink-0">
            <h1 class="text-4xl font-bold mb-4 text-[#cfb4b8] text-center font-serif">El Oráculo</h1>
            <p class="text-lg text-texto/70 mb-10 text-center italic px-4">Reflexiones espirituales, tiradas interactivas y magia tecnológica.</p>
        </header>

        <InstagramFeed />
        <YouTubeFeed />

        <h2 class="text-3xl font-serif text-texto text-center mb-10 italic tracking-widest uppercase">Blog</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
            {postsOrdenados.map((post) => (
                <article class="group relative border border-white/50 rounded-[35px] shadow-sm hover:shadow-lg transition-all duration-500 hover:-translate-y-2 overflow-hidden flex flex-col h-full">
                    
                    {post.data.image ? (
                        <div class="absolute inset-0 z-0">
                            <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                            <div class="absolute inset-0 bg-white/40 backdrop-blur-md group-hover:bg-white/30 transition-colors duration-500"></div>
                        </div>
                    ) : (
                        <div class="absolute inset-0 bg-white/20 backdrop-blur-xl group-hover:bg-white/30 transition-colors duration-500 z-0"></div>
                    )}

                    <div class="relative z-10 p-8 flex flex-col h-full">
                        <div class="flex flex-wrap gap-2 mb-4">
                            {post.data.tags.map(tag => (
                                <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-[#cfb4b8] bg-white/60 border border-white px-3 py-1 rounded-full shadow-sm">
                                    #{tag}
                                </span>
                            ))}
                        </div>

                        <h2 class="text-2xl font-serif font-bold text-texto mb-3 leading-tight italic">
                            <a href={`/blog/${post.id}`} class="hover:text-[#cfb4b8] transition-colors">
                                {post.data.title}
                            </a>
                        </h2>

                        <p class="text-texto/70 text-sm mb-6 line-clamp-3 leading-relaxed font-medium flex-grow">
                            {post.data.description}
                        </p>

                        <div class="flex items-center justify-between border-t border-white/30 pt-4 mt-auto">
                            <span class="text-[10px] font-bold text-texto/50 uppercase tracking-widest">
                                {post.data.pubDate.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}
                            </span>
                            
                            <a href={`/blog/${post.id}`} class="text-xs font-bold tracking-[0.1em] text-[#cfb4b8] hover:text-[#bfa3a7] transition-colors">
                                LEER →
                            </a>
                        </div>
                    </div>
                </article>
            ))}
        </div>

        <div class="text-center mt-16 relative z-10">
            <a href="/archivo" class="inline-block border-2 border-[#cfb4b8] text-[#cfb4b8] hover:bg-[#cfb4b8] hover:text-white font-bold tracking-widest text-sm px-10 py-4 rounded-full transition-all duration-300 shadow-sm hover:shadow-md hover:-translate-y-1">
                EXPLORAR EL ARCHIVO MÍSTICO
            </a>
        </div>

        <footer class="mt-24 text-center pb-10">
            <div class="flex items-center justify-center gap-4 mb-8 opacity-40">
                <div class="h-[1px] w-20 bg-texto"></div>
                <span class="text-xl">☁️</span>
                <div class="h-[1px] w-20 bg-texto"></div>
            </div>
            <p class="text-texto/40 text-sm font-serif italic tracking-wide">
                El conocimiento del oráculo se renueva con cada ciclo lunar.
            </p>
        </footer>
    </div>
</Layout>

<style>
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>