---
import Layout from '../layouts/Layout.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import YouTubeFeed from '../components/YouTubeFeed.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import nubeImg from '../assets/nube.png';

const posts = await getCollection('oraculo');
const postsOrdenados = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<Layout title="El Oráculo - Blog">
    <div class="max-w-[1100px] mx-auto py-12 px-6 relative z-10">
        
        <div class="absolute -top-10 -left-60 opacity-100 -z-10 pointer-events-none">
            <Image src={nubeImg} alt="Nube" class="w-100 h-auto" />
        </div>
        <div class="absolute top-50 -right-90 opacity-100 -z-10 pointer-events-none">
            <Image src={nubeImg} alt="Nube" class="w-120 h-auto scale-x-[-1]" />
        </div>

        <header class="text-center mb-12 md:mb-20 shrink-0">
            <h1 class="cabecera-titulo">El Oráculo</h1>
            <p class="cabecera-subtitulo">Reflexiones espirituales, tiradas interactivas y magia tecnológica.</p>
        </header>

        <InstagramFeed />
        <YouTubeFeed />

        <h2 class="titulo-seccion mt-16">Blog</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 relative z-10">
            {postsOrdenados.map((post) => (
                <article class="card-cristal group !p-0 overflow-hidden">
                    
                    {post.data.image ? (
                        <div class="absolute inset-0 z-0">
                            <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                            <div class="absolute inset-0 bg-white/40 backdrop-blur-md group-hover:bg-white/30 transition-colors duration-500"></div>
                        </div>
                    ) : (
                        <div class="absolute inset-0 bg-white/20 backdrop-blur-xl group-hover:bg-white/30 transition-colors duration-500 z-0"></div>
                    )}

                    <div class="relative z-10 p-6 md:p-8 flex flex-col h-full">
                        <div class="flex flex-wrap gap-2 mb-4">
                            {post.data.tags.map(tag => (
                                <span class="tag-mistica !text-rosa !bg-white/80">
                                    #{tag}
                                </span>
                            ))}
                        </div>

                        <h2 class="text-xl md:text-2xl font-serif font-bold text-texto mb-3 leading-tight italic">
                            <a href={`/blog/${post.id}`} class="group-hover:text-rosa transition-colors duration-300">
                                {post.data.title}
                            </a>
                        </h2>

                        <p class="text-texto/70 text-sm mb-6 line-clamp-3 leading-relaxed font-medium flex-grow">
                            {post.data.description}
                        </p>

                        <div class="flex items-center justify-between border-t border-white/30 pt-4 mt-auto">
                            <span class="text-[10px] font-bold text-texto/50 uppercase tracking-widest">
                                {post.data.pubDate.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}
                            </span>
                            
                            <a href={`/blog/${post.id}`} class="text-xs font-bold tracking-[0.1em] text-rosa hover:opacity-70 transition-all uppercase">
                                LEER →
                            </a>
                        </div>
                    </div>
                </article>
            ))}
        </div>

        <div class="text-center mt-12 md:mt-16 relative z-10">
            <a href="/archivo" class="inline-block border-2 border-rosa text-rosa hover:bg-rosa hover:text-white font-bold tracking-widest text-xs md:text-sm px-8 md:px-10 py-3 md:py-4 rounded-full transition-all duration-300 shadow-sm hover:shadow-md hover:-translate-y-1">
                EXPLORAR EL ARCHIVO MÍSTICO
            </a>
        </div>

        <section class="py-20 px-6 text-center">
            <div class="tarjeta-cristal max-w-4xl mx-auto !p-12">
                <h2 class="text-3xl font-serif text-texto mb-6 italic">¿Buscas el mensaje de una carta?</h2>
                <p class="text-texto/70 mb-8 max-w-xl mx-auto">
                    Hemos canalizado la sabiduría de los 78 arcanos en nuestro nuevo diccionario místico. 
                    Busca tu carta y descubre qué tiene que decirte el universo hoy.
                </p>
                <a href="/blog/tarot" class="bg-rosa text-white font-bold tracking-[0.2em] text-[12px] px-10 py-5 rounded-full shadow-[0_5px_0_#a88e92] hover:translate-y-1 hover:shadow-none transition-all active:scale-95 inline-block cursor-pointer">
                    EXPLORAR DICCIONARIO
                </a>
            </div>
        </section>

        <footer class="mt-10 text-center pb-10">
            <div class="flex items-center justify-center gap-4 mb-1 opacity-40">
                <div class="h-[1px] w-20 bg-texto"></div>
                <span class="text-xl">☁️</span>
                <div class="h-[1px] w-20 bg-texto"></div>
            </div>
            <p class="text-texto/40 text-sm font-serif italic tracking-wide">
                El conocimiento del oráculo se renueva con cada ciclo lunar.
            </p>
        </footer>
    </div>
</Layout>