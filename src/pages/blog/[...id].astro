---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const posts = await getCollection('oraculo');
    return posts.map((post) => ({
        params: { id: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout 
    title={post.data.title} 
    description={post.data.description} 
    image={post.data.image}
>
    <div class="flex-1 flex flex-col justify-center items-center w-full relative z-10 md:h-[calc(85vh-12rem)] md:min-h-0">

        <header class="text-center mb-6 shrink-0 mt-4 md:mt-0">
            <p class="cabecera-subtitulo !mb-2">
                {post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
            <h1 class="cabecera-titulo">
                {post.data.title}
            </h1>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 w-full max-w-[1100px] md:flex-1 md:min-h-0 pb-2 px-4">
            
            <section class="md:col-span-7 tarjeta-cristal !p-8 flex flex-col md:h-full md:overflow-hidden">
                <h2 class="titulo-cristal italic shrink-0">Mensaje Sagrado</h2>
                
                <div class="md:flex-1 md:overflow-y-auto md:min-h-0 pr-2 md:pr-4 custom-scrollbar prose-texto">
                    <Content />
                </div>
            </section>

            <section class="md:col-span-5 tarjeta-azul flex flex-col md:h-full md:overflow-hidden">
                <h2 class="titulo-cristal !border-white/20 italic shrink-0">Simbolismos</h2>
                
                <div class="flex flex-wrap gap-2 mb-4 shrink-0">
                    {post.data.tags.map((tag: string) => (
                        <span class="tag-mistica">
                            #{tag}
                        </span>
                    ))}
                </div>
                
                <p class="text-texto font-serif italic text-sm leading-relaxed mb-4 shrink-0 opacity-80">
                    {post.data.description}
                </p>

                {post.data.image && (
                    <div class="contenedor-foto-blog">
                        <img 
                            src={post.data.image} 
                            alt={post.data.title} 
                            class="absolute inset-0 w-full h-full object-cover" 
                            loading="lazy" 
                        />
                    </div>
                )}
                
                <a href="/blog" class="btn-volver">
                    VOLVER AL ORÁCULO
                </a>
            </section>
        </div>
    </div>
</Layout>

<style>
    @media (min-width: 768px) {
        html, body { 
            overflow: hidden !important; 
        }
    }
</style>