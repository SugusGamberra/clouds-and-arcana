---
import Layout from '../../layouts/Layout.astro';
import { deck, obtenerRutaImagen } from '../../data/tarot';
---

<Layout 
    title="Diccionario de Tarot | Significado de las Cartas" 
    description="Explora el significado de las 78 cartas del Tarot. Descubre el mensaje espiritual que los arcanos tienen preparado para ti."
>
    <div class="flex-1 flex flex-col items-center w-full relative z-10 py-10 px-4 md:px-8 max-w-6xl mx-auto">
        
        <header class="text-center mb-12">
            <h1 class="cabecera-titulo !mb-2 uppercase tracking-widest">
                Diccionario del Tarot
            </h1>
            <p class="cabecera-subtitulo !mb-0 max-w-2xl mx-auto">
                Selecciona una carta para descubrir su mensaje espiritual y su significado oculto en el Oráculo.
            </p>
        </header>

        <div class="grid grid-cols-3 md:grid-cols-5 lg:grid-cols-7 gap-4 md:gap-8 w-full">
            {deck.map((carta) => {
                const slug = carta.nombre
                    .toLowerCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .replace(/\s+/g, '-');
                
                const imagePath = obtenerRutaImagen(carta.nombre);

                return (
                    <a href={`/tarot/${slug}`} class="group flex flex-col items-center gap-3 hover:-translate-y-2 transition-all duration-300">
                        
                        <img 
                            src={imagePath} 
                            alt={`Carta ${carta.nombre}`}
                            class="w-full aspect-[2/3] object-contain rounded-xl drop-shadow-md group-hover:drop-shadow-2xl transition-all duration-300"
                            loading="lazy"
                        />
                        
                        <h2 class="text-center text-texto font-bold text-[9px] md:text-[10px] tracking-widest uppercase opacity-60 group-hover:opacity-100 group-hover:text-rosa transition-all">
                            {carta.nombre}
                        </h2>
                    </a>
                );
            })}
        </div>

    </div>
</Layout>