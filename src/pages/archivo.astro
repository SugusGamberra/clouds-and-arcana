---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('oraculo');
const postsOrdenados = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Archivo Místico - Clouds & Arcana">
    <div class="max-w-6xl mx-auto py-12 px-6 relative z-10">
        
        <header class="text-center mb-16 shrink-0">
            <h1 class="text-5xl font-serif text-texto font-bold mb-4 tracking-tight leading-none italic">
                Archivo Místico
            </h1>
            <p class="text-lg text-texto/60 font-serif italic max-w-2xl mx-auto">
                Toda la sabiduría pasada del oráculo, guardada en las nubes.
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative z-10">
            {postsOrdenados.map((post) => (
                <article class="bg-white/20 backdrop-blur-xl border border-white/50 p-8 rounded-[35px] shadow-sm hover:shadow-lg hover:bg-white/30 transition-all duration-500 hover:-translate-y-2 flex flex-col h-full">
                    
                    <div class="flex flex-wrap gap-2 mb-4">
                        {post.data.tags.map(tag => (
                            <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-[#cfb4b8] bg-white/60 border border-white px-3 py-1 rounded-full shadow-sm">
                                #{tag}
                            </span>
                        ))}
                    </div>

                    <h2 class="text-2xl font-serif font-bold text-texto mb-3 leading-tight italic">
                        <a href={`/blog/${post.id}`} class="hover:text-[#cfb4b8] transition-colors">
                            {post.data.title}
                        </a>
                    </h2>

                    <p class="text-texto/70 text-sm mb-6 line-clamp-3 leading-relaxed font-medium flex-grow">
                        {post.data.description}
                    </p>

                    <div class="flex items-center justify-between border-t border-white/30 pt-4 mt-auto">
                        <span class="text-[10px] font-bold text-texto/50 uppercase tracking-widest">
                            {post.data.pubDate.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}
                        </span>
                        
                        <a href={`/blog/${post.id}`} class="text-xs font-bold tracking-[0.1em] text-[#cfb4b8] hover:text-[#bfa3a7] transition-colors">
                            LEER →
                        </a>
                    </div>
                </article>
            ))}
        </div>

        <div class="text-center mt-16">
            <a href="/blog" class="text-sm font-bold tracking-widest text-texto/50 hover:text-[#cfb4b8] transition-colors uppercase">
                ← Volver al Oráculo
            </a>
        </div>
    </div>
</Layout>