---
export interface Props {
    stock: number;
}

const { stock } = Astro.props;
---

<div class="flex flex-col items-center gap-4 text-center">
    <p class="text-xs font-bold text-rosa uppercase tracking-widest">
        🤍 ¡Solo para los {stock} primeros! 🤍
    </p>
    
    <a 
        href={import.meta.env.PUBLIC_FORM_URL} 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-block px-10 py-4 bg-[#cfb4b8] text-white rounded-full font-bold shadow-[0_4px_0_#a88e92] hover:translate-y-1 hover:shadow-none transition-all active:scale-95 cursor-pointer uppercase tracking-widest text-[11px]"
    >
        SOLICITAR MI PLAZA GRATIS
    </a>
    
    <p class="text-[9px] text-texto/40 italic mt-1 uppercase tracking-wider">
        *Asignación por estricto orden de llegada
    </p>
</div>