---
import '../styles/global.css';
import { Image } from 'astro:assets';
import background from '../assets/background.png';
import nubeImg from '../assets/nube.png';

interface Props {
    title: string;
    description?: string;
    image?: string;
}

const { 
    title, 
    description = "Lectura de Tarot, Runas e Interpretación de Sueños con enfoque espiritual y tecnológico. Descubre los mensajes que el universo tiene para ti.",
    image = "/img-share.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="google-site-verification" content="cDU-bwfHdS0dU-k2Nqvn4mN1lN7RKVjGxRAei-mwg3c" />
        <link rel="canonical" href={canonicalURL} />
        <meta name="robots" content="index, follow" />

        <title>{title} | Clouds & Arcana</title>
        <link rel="icon" type="image/png" href="/favicon.png" />

        <meta name="description" content={description} />
        <meta name="keywords" content="Tarot, Runas, Sueños, Espiritualidad, Lectura de cartas, Oráculo" />
        <meta name="author" content="Clouds & Arcana" />

        <meta property="og:type" content="website" />
        <meta property="og:title" content={`${title} | Clouds & Arcana`} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={image} /> 
        <meta property="og:url" content={canonicalURL} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={image} />

        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "ProfessionalService",
            "name": "Clouds & Arcana",
            "description": "Interpretación de sueños, lectura de tarot y runas con enfoque espiritual y tecnológico.",
            "url": "https://cloudsandarcana.vercel.app",
            "address": {
                "@type": "PostalAddress",
                "addressCountry": "ES"
            }
        }
        </script>
    </head>
    <body class="bg-[#eef5fa] text-texto font-sans min-h-screen flex flex-col relative overflow-x-hidden">
        
        <header class="sticky top-0 z-50 py-4 px-6 md:px-8 bg-white/40 backdrop-blur-md border-b border-white/30 shadow-sm">
            <nav class="max-w-5xl mx-auto flex flex-wrap justify-between items-center relative">
                
                <a href="/" class="flex items-center gap-3 group transition-transform hover:scale-105 font-serif text-texto z-20">
                    <img src="/favicon.png" alt="Logo" class="w-12 h-12 md:w-15 md:h-15 object-contain group-hover:rotate-12 transition-transform duration-500" />
                    <span class="text-lg md:text-xl leading-none tracking-widest font-bold italic uppercase">
                        CLOUDS &<br/><span class="text-[#cfb4b8]">ARCANA</span>
                    </span>
                </a>

                <button id="mobile-menu-btn" aria-label="Abrir menú" class="md:hidden flex flex-col justify-center items-center w-12 h-12 bg-white/50 rounded-full text-[#cfb4b8] focus:outline-none z-20 shadow-sm border border-white/60">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>

                <ul class="hidden md:flex gap-8 items-center uppercase z-20">
                    <li><a href="/" class="nav-link">Inicio</a></li>
                    <li><a href="/sobre-mi" class="nav-link">Sobre mí</a></li>
                    <li><a href="/blog" class="nav-link">El Oráculo</a></li>
                    
                    <li class="relative group">
                        <button class="bg-[#cfb4b8] text-white font-bold tracking-[0.2em] text-[10px] px-6 py-2.5 rounded-full shadow-[0_4px_0_#a88e92] hover:translate-y-1 hover:shadow-none transition-all active:scale-95 flex items-center gap-1 cursor-pointer">
                            RESERVAR
                            <svg class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        
                        <div class="absolute top-full right-0 mt-3 w-64 bg-white/90 backdrop-blur-xl border border-white/50 rounded-2xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 flex flex-col overflow-hidden text-left z-50">
                            <a href="/reservar/tarot" class="dropdown-link">Tarot y Guía Espiritual</a>
                            <a href="/reservar/runas" class="dropdown-link">Magia Nórdica y Runas</a>
                            <a href="/reservar/suenos" class="dropdown-link">El Mundo de los Sueños</a>
                            <a href="/reservar/rituales" class="dropdown-link">Rituales y Hechizos</a>
                            <a href="/reservar/limpiezas" class="dropdown-link">Limpiezas Energéticas</a>
                            <a href="/reservar/promociones" class="dropdown-link">Promociones</a>
                        </div>
                    </li>

                    <li class="relative flex items-center">
                        <a href="/carrito" id="cart-desktop-btn" class="hover:scale-110 transition-transform cursor-pointer relative inline-block group" aria-label="Ver carrito">
                            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#cfb4b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-[#8e7579] transition-colors">
                                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
                                <path d="M3 6h18"></path>
                                <path d="M16 10a4 4 0 0 1-8 0"></path>
                            </svg>
                            <span id="cart-count-desktop" class="cart-badge">0</span>
                        </a>
                    </li>
                </ul>

                <div id="mobile-menu" class="hidden absolute top-full left-0 w-full mt-4 bg-white/90 backdrop-blur-xl border border-white/50 rounded-[30px] shadow-lg flex-col p-8 gap-4 text-center uppercase z-10">
                    <a href="/" class="nav-link-mobile">Inicio</a>
                    <a href="/sobre-mi" class="nav-link-mobile">Sobre mí</a>
                    <a href="/blog" class="nav-link-mobile">El Oráculo</a>
                    
                    <details class="w-full group/reserva relative mt-2">
                        <summary class="list-none flex items-center justify-center gap-2 bg-[#cfb4b8] text-white font-bold tracking-[0.2em] text-[12px] px-8 py-4 rounded-full shadow-[0_4px_0_#a88e92] mx-auto w-max cursor-pointer active:scale-95 transition-transform">
                            RESERVAR
                            <svg class="w-4 h-4 transition-transform group-open/reserva:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </summary>
                        <div class="flex flex-col mt-4 bg-white/50 rounded-2xl overflow-hidden text-center border border-white/50 shadow-inner">
                            <a href="/reservar/tarot" class="nav-link-mobile text-[11px] hover:bg-white/60">Tarot y Guía Espiritual</a>
                            <a href="/reservar/runas" class="nav-link-mobile text-[11px] hover:bg-white/60">Magia Nórdica y Runas</a>
                            <a href="/reservar/suenos" class="nav-link-mobile text-[11px] hover:bg-white/60">El Mundo de los Sueños</a>
                            <a href="/reservar/rituales" class="nav-link-mobile text-[11px] hover:bg-white/60">Rituales y Hechizos</a>
                            <a href="/reservar/limpiezas" class="nav-link-mobile text-[11px] hover:bg-white/60 border-none">Limpiezas Energéticas</a>
                        </div>
                    </details>

                    <div class="flex items-center justify-center mt-5 mb-2">
                        <a href="/carrito" id="cart-mobile-btn" class="hover:scale-110 transition-transform cursor-pointer relative inline-block group" aria-label="Ver carrito">
                            <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#cfb4b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-[#8e7579] transition-colors">
                                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
                                <path d="M3 6h18"></path>
                                <path d="M16 10a4 4 0 0 1-8 0"></path>
                            </svg>
                            <span id="cart-count-mobile" class="cart-badge-mobile">0</span>
                        </a>
                    </div>
                </div>
            </nav>
        </header>

        <div class="fixed inset-0 w-full h-full -z-10">
            <Image 
                src={background} 
                alt="Fondo místico" 
                class="w-full h-full object-cover opacity-90 object-top"
            />
        </div>

        <main class="flex-grow p-4 md:p-8 relative z-10">
            <slot /> 
        </main>

        <footer class="bg-[#d0b2b6] py-10 text-center text-texto mt-auto w-full z-20 shadow-[0_-5px_15px_rgba(0,0,0,0.05)] relative">
            <div class="absolute bottom-[0px] -right-50 z-20 pointer-events-none hidden md:block">
                <Image 
                    src={nubeImg} 
                    alt="Nube decorativa" 
                    class="w-180 h-auto opacity-100 scale-x-[-1]" 
                />
            </div>

            <div class="relative z-30 max-w-5xl mx-auto px-4 flex flex-col items-center justify-center gap-6"> 
                <div class="flex flex-wrap justify-center items-center gap-4 text-[10px] md:text-xs font-bold tracking-widest uppercase text-texto text-opacity-60">
                    <a href="/faq" class="hover:text-white transition-colors">Preguntas Frecuentes</a>
                    <span class="opacity-30">|</span>
                    <a href="/contacto" class="hover:text-white transition-colors">Contacto</a>
                    <span class="opacity-30">|</span>
                    <a href="/resenas" class="hover:text-white transition-colors">Reseñas</a>
                    <span class="opacity-30">|</span>
                    <a href="/privacidad" class="hover:text-white transition-colors">Privacidad</a>
                    <span class="opacity-30">|</span>
                    <a href="/terminos" class="hover:text-white transition-colors">Términos</a>
                </div>

                <div class="flex justify-center items-center gap-6">
                    <a href="https://www.instagram.com/cloudsarcana/" target="_blank" rel="noopener noreferrer" class="hover:scale-110 transition-transform group" aria-label="Instagram">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-texto text-opacity-60 group-hover:text-white transition-colors"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    </a>
                    <a href="https://www.youtube.com/@CloudsArcana" target="_blank" rel="noopener noreferrer" class="hover:scale-110 transition-transform group" aria-label="YouTube">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-texto text-opacity-60 group-hover:text-white transition-colors"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
                    </a>
                </div>
                
                <p class="text-[10px] md:text-xs font-bold tracking-wider text-center text-texto text-opacity-50 mt-2">
                    © 2026 Clouds & Arcana. Todos los derechos reservados.
                </p>
            </div>
        </footer>

        <script>
            // Lógica Menú
            const btn = document.getElementById('mobile-menu-btn');
            const menu = document.getElementById('mobile-menu');
            if (btn && menu) {
                btn.addEventListener('click', () => {
                    menu.classList.toggle('hidden');
                    menu.classList.toggle('flex');
                });
            }

            // Lógica Carrito
            let carrito = JSON.parse(localStorage.getItem('carritoClouds') || '[]');
            function actualizarContadores() {
                const countDesktop = document.getElementById('cart-count-desktop');
                const countMobile = document.getElementById('cart-count-mobile');
                const totalItems = carrito.length;
                [countDesktop, countMobile].forEach(el => {
                    if (el) {
                        el.textContent = totalItems.toString();
                        el.classList.toggle('hidden', totalItems === 0);
                    }
                });
            }
            actualizarContadores();

            document.addEventListener('click', (e) => {
                let target = e.target as any;
                if (target && target.nodeType === 3) target = target.parentNode;
                if (!target || typeof target.closest !== 'function') return;
                const botonAnadir = target.closest('.add-to-cart-btn');
                if (!botonAnadir) return; 

                const id = botonAnadir.getAttribute('data-id');
                const nombre = botonAnadir.getAttribute('data-nombre');
                const precio = parseFloat(botonAnadir.getAttribute('data-precio') || '0');

                carrito.push({ id, nombre, precio });
                localStorage.setItem('carritoClouds', JSON.stringify(carrito));
                actualizarContadores();

                const textoOriginal = botonAnadir.innerHTML;
                botonAnadir.innerHTML = '¡AÑADIDO! ☁️';
                botonAnadir.classList.add('bg-[#8e7579]', 'scale-105');
                setTimeout(() => {
                    botonAnadir.innerHTML = textoOriginal;
                    botonAnadir.classList.remove('bg-[#8e7579]', 'scale-105');
                }, 1000);
            });
        </script>
    </body>
</html>